{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {}
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals", "{workspaceRoot}/.github/workflows/pr.yml"],
    "assets": ["{workspaceRoot}/assets/**/*"],
    "iconGenerationToolchain": [
      "{workspaceRoot}/importer/generate.js",
      "{workspaceRoot}/importer/replace-in-files.js",
      "{workspaceRoot}/importer/svgo.config.shared.cjs"
    ],
    "fontGenerationToolchain": [
      "iconGenerationToolchain",
      "{workspaceRoot}/importer/generateFont.js",
      "{workspaceRoot}/importer/svgo.config.mjs",
      "{workspaceRoot}/importer/package.json"
    ],
    "fontArtifacts": [
      "{workspaceRoot}/fonts/FluentSystemIcons-*.ttf",
      "{workspaceRoot}/fonts/FluentSystemIcons-*.woff",
      "{workspaceRoot}/fonts/FluentSystemIcons-*.woff2",
      "{workspaceRoot}/fonts/FluentSystemIcons-*.json"
    ],
    "sharedGlobals": []
  },
  "release": {
    "groups": {
      "react": {
        "projects": [
          "packages/react-icons",
          "packages/react-icons-font-subsetting-webpack-plugin",
          "packages/react-native-icons"
        ],
        "projectsRelationship": "independent"
      },
      "native": {
        "projects": ["packages/svg-icons", "packages/svg-sprites"],
        "projectsRelationship": "independent"
      },
      "standalone": {
        "projects": [
          "packages/react-icons-atomic-webpack-loader",
          "packages/react-icons-svg-sprite-subsetting-webpack-plugin",
          "packages/react-icons-file-type",
          "packages/eslint-plugin-react-icons"
        ],
        "projectsRelationship": "independent",
        "version": {
          "adjustSemverBumpsForZeroMajorVersion": true
        }
      }
    },
    "version": {
      "conventionalCommits": true,
      "updateDependents": "auto",
      "preserveMatchingDependencyRanges": ["devDependencies"],
      "fallbackCurrentVersionResolver": "disk",
      "git": {
        "commit": false,
        "tag": false,
        "commitMessage": "chore(release): version {projectName} {version}"
      },
      "versionActionsOptions": {
        "skipLockFileUpdate": true
      }
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "entryWhenNoChanges": "This release contains icon updates",
        "renderOptions": {
          "authors": false,
          "commitReferences": true,
          "versionTitleDate": true
        },
        "git": {
          "commit": false,
          "commitMessage": "chore(release): update {projectName} changelog for {version}"
        }
      }
    }
  },
  "tui": {
    "enabled": false
  },
  "analytics": false
}

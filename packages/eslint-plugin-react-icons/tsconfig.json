{
  "compilerOptions": {
    "types": ["node"],
    "target": "es2020",
    "module": "esnext",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}

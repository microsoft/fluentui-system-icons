{
  "name": "@fluentui/react-native-icons-modular",
  "version": "0.1.0",
  "sideEffects": false,
  "main": "lib/index.js",
  "module": "lib/index.js",
  "typings": "lib/index.d.ts",
  "description": "Fluent System Icons for React Native — modular per-icon exports for optimal Metro bundling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/fluentui-system-icons.git",
    "directory": "packages/react-native-icons-modular"
  },
  "scripts": {
    "clean": "rm -rf src/icons src/sizedIcons lib",
    "cleanSrc": "rm -rf src/icons src/sizedIcons",
    "copy": "node ../../importer/generate.js --source=../../assets --dest=./intermediate --extension=svg --target=react",
    "optimize": "svgo --config ../react-native-icons/svgo.config.js --folder=./intermediate --precision=2 --quiet",
    "unfill": "find ./intermediate -type f -name \"*.svg\" -exec sed -i.bak 's/fill=\"none\"//g' {} \\; && find ./intermediate -type f -name \"*.bak\" -delete",
    "convert": "node ./convert-rn-modular.cjs --source=./intermediate --dest=./src",
    "generate-exports": "node ./generate-exports-map.cjs",
    "restore-exports": "node ./generate-exports-map.cjs --restore",
    "cleanSvg": "rm -rf ./intermediate",
    "build:esm": "tsc -p . && babel lib --out-dir lib",
    "build": "npm run copy && npm run optimize && npm run unfill && npm run convert && npm run cleanSvg && npm run build:esm && npm run cleanSrc",
    "build:pack": "npm pack && npm run clean",
    "prepack": "npm run build && npm run generate-exports",
    "postpack": "npm run restore-exports"
  },
  "devDependencies": {
    "@babel/cli": "^7.16.0",
    "@babel/core": "^7.16.0",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.16.7",
    "@svgr/core": "^6.5.1",
    "@types/react": "^17.0.2",
    "glob": "^7.2.0",
    "lodash": "^4.18.1",
    "mkdirp": "^1.0.4",
    "react": "^17.0.1",
    "react-native": "^0.68.0",
    "svgo": "2.8.2",
    "typescript": "4.1.6",
    "yargs": "^14.0.0"
  },
  "dependencies": {
    "@types/react-native": "^0.68.0",
    "tslib": "^2.1.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <19.0.0",
    "react-native-svg": ">=12.5.0"
  },
  "files": [
    "lib/"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./utils/*": {
      "types": "./lib/utils/*.d.ts",
      "import": "./lib/utils/*.js",
      "default": "./lib/utils/*.js"
    }
  },
  "nx": {
    "tags": [
      "npm:public"
    ]
  }
}

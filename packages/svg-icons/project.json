{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "svg-icons",
  "projectType": "library",
  "tags": ["platform:web"],
  "implicitDependencies": ["system-icons-processing"],
  "targets": {
    "build": {
      "cache": true,
      "inputs": [
        "assets",
        "iconGenerationToolchain",
        "{projectRoot}/package.json",
        "{projectRoot}/svgo.config.js",
        "{projectRoot}/unfill.js"
      ],
      "outputs": ["{projectRoot}/icons"]
    }
  }
}

{
  "compilerOptions": {
    "types": ["node"],
    "target": "es2020",
    "module": "nodenext",
    "rootDir": "./src",
    "moduleResolution": "nodenext",
    "declaration": true,
    "outDir": "./lib",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}

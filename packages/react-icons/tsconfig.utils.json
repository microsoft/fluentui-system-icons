{
  "compilerOptions": {
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "noEmit": true,
    "module": "commonjs",
    "target": "es2020",
    "allowJs": true,
    "checkJs": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "pretty": true
  },
  "include": ["scripts/"]
}

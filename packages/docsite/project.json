{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "docsite",
  "projectType": "application",
  "sourceRoot": "packages/docsite/src",
  "tags": ["platform:web"],
  "targets": {
    "build": {
      "cache": true,
      "inputs": ["{projectRoot}/.storybook/**", "{projectRoot}/stories/**", "{projectRoot}/public/**"],
      "outputs": ["{projectRoot}/storybook-static"]
    },
    "lint": {
      "cache": true,
      "inputs": ["{projectRoot}/stories/**", "{projectRoot}/.storybook/**", "{projectRoot}/eslint.config.mjs"]
    },
    "extract-storybook-llms": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": [{ "externalDependencies": ["@fluentui/storybook-llms-extractor"] }],
      "outputs": ["{projectRoot}/storybook-static/llms", "{projectRoot}/storybook-static/llms.txt"]
    }
  }
}
